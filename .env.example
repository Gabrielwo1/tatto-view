VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ══════════════════════════════════════════════════════
# ImgBB — fallback de hospedagem de imagens (opcional se usar Supabase)
# https://api.imgbb.com/
# ══════════════════════════════════════════════════════
VITE_IMGBB_API_KEY=sua_chave_aqui
